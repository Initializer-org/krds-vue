{
  "name": "@krds.ui/vue",
  "version": "0.0.13",
  "description": "KRDS Vue Design System - 한국 정부 디자인 시스템 Vue 컴포넌트 라이브러리",
  "keywords": [
    "krds",
    "design-system",
    "vue",
    "vue3",
    "components",
    "ui-library",
    "typescript",
    "korea",
    "government"
  ],
  "homepage": "https://krds.initializer.org",
  "bugs": {
    "url": "https://github.com/Initializer-org/krds-vue/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Initializer-org/krds-vue.git"
  },
  "license": "MIT",
  "author": "Initializer Team",
  "type": "module",
  "main": "./dist/krds-vue.umd.js",
  "module": "./dist/krds-vue.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/krds-vue.es.js",
      "require": "./dist/krds-vue.umd.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./style": "./dist/style.css",
    "./styles/*": "./dist/styles/*",
    "./styles": {
      "types": "./dist/types/styles/index.d.ts",
      "import": "./dist/styles/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm run type-check && pnpm run build:lib",
    "build:lib": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "bundle-size": "vite build && echo 'Bundle size check removed due to bundlewatch security vulnerability'",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/vue3-vite": "^10.2.10",
    "@tsconfig/node20": "^20.1.8",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.1",
    "eslint-plugin-storybook": "^10.2.10",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "source-map-explorer": "^2.5.3",
    "standard-version": "^9.5.0",
    "storybook": "^10.2.10",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.28",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "lodash": ">=4.17.23",
      "eslint>ajv": "6.14.0",
      "@eslint/eslintrc>ajv": "6.14.0",
      "@microsoft/tsdoc-config>ajv": ">=8.18.0",
      "@rushstack/node-core-library>ajv": ">=8.18.0",
      "@microsoft/api-extractor>diff": ">=8.0.3",
      "minimatch": ">=10.2.1"
    }
  }
}
